<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_header.xml  –  Exambro-style header
    ✔ Warna  : #4CAF50  (sama dengan Exambro asli)
    ✔ Font   : sans-serif-medium, bold, 18sp  (sama)
    ✔ Tinggi : 56dp total  (padding 8dp atas-bawah + konten 40dp)
    ✔ Tambah : tampilan JAM di kanan  (seperti Exambro asli)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="#4CAF50"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="4dp"
    android:elevation="8dp">

    <!-- Nama Aplikasi (kiri) -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Exambro"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.01" />

    <!-- Jam digital (kanan) – diupdate tiap detik dari OverlayService -->
    <TextView
        android:id="@+id/tvClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:paddingEnd="4dp" />

    <!-- Tombol 3 titik (kanan) -->
    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        android:tint="#FFFFFF"
        android:contentDescription="Menu" />

</LinearLayout>